# --- Ollama Configuration ---
OLLAMA_URL=http://localhost:11434/api/chat
# LLAMA_MODEL=llama3.2 was to bad with lithuanian overall not bad for 2 gb model
OLLAMA_MODEL=gemma2:9b # 5.4 gb model

# --- OpenAI Configuration (optional, used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo


# --- LLM Provider: "ollama" or "openai" ---
LLM_PROVIDER=ollama

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Retrieval ---
TOP_K=5
CHUNK_SIZE=300
CHUNK_OVERLAP=50
