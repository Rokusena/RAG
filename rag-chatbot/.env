# --- Ollama Configuration ---
OLLAMA_URL=http://localhost:11434/api/chat
# Previous models: llama3.2 (2GB, weak Lithuanian), gemma2:9b (5.4GB), qwen3:8b (4.9GB)
OLLAMA_MODEL=qwen3.5:9B


# --- LLM Provider: "ollama" or "openai" ---
LLM_PROVIDER=ollama

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Retrieval ---
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=75
